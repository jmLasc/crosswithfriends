{
  "compilerOptions": {
"target": "es2022",
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "allowJs": true,
    "skipLibCheck": true,
    "types": ["vite/client", "jest", "node"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@shared/*": ["../src/shared/*"],
      "@lib/*": ["../src/lib/*"]
    }
  },
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node"
    }
  },
  "include": [".", "../src/lib", "../src/shared"],
  "exclude": ["../src/**/__tests__/**"]
}
