    "react-confetti": "^6.4.0",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-helmet-async": "^2.0.5",
    "react-icons": "^5.6.0",
    "react-router": "^7.13.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typescript": "~5.9.3",
    "uuid": "^11.1.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "esbuild": "^0.27.4",
      "serialize-javascript": "^7.0.3",
      "diff": "^5.2.0",
      "glob": "^13.0.6",
      "test-exclude>glob": "7",
      "undici": ">=7.24.0",
      "flatted": ">=3.4.2",
      "socket.io-parser": ">=4.2.6",
      "axios": ">=1.15.0"
    },
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@sentry/vite-plugin": "^5.1.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.19.15",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.20.0",
    "@types/qs": "^6.15.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^5.2.0",
    "argparse": "^2.0.1",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "start": "vite --port 3020 --strictPort",
    "devfrontend": "cross-env VITE_USE_LOCAL_SERVER=1 vite --port 3020 --strictPort",
    "devfrontendprod": "cross-env VITE_ENV=production VITE_USE_LOCAL_SERVER=1 vite --port 3020 --strictPort",
    "devbackend": "dotenv -e server/.env.local -- cross-env PORT=3021 nodemon --watch server -e \"ts\" --exec \"npx ts-node -P server/tsconfig.json server/server.ts\"",
    "devbackendprod": "dotenv -e .env.prod -- cross-env PORT=3021 nodemon --watch server -e \"ts\" --exec \"npx ts-node -P server/tsconfig.json server/server.ts\"",
    "servebackendprod": "while true; do env $(cat .env.prod | xargs)  NODE_ENV=production PORT=3021 ts-node -P server/tsconfig.json server/server.ts || true; done",
    "servebackendstaging": "while true; do env $(cat .env.staging | xargs)  NODE_ENV=production PORT=4021 ts-node -P server/tsconfig.json server/server.ts || true; done",
    "build": "vite build",
    "preview": "vite preview --port 3020",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:server": "jest --config jest.config.server.js",
    "prepare": "husky",
    "test:e2e": "npx playwright test --config=e2e/playwright.config.ts",
    "test:e2e:headed": "npx playwright test --config=e2e/playwright.config.ts --headed",
    "test:e2e:ui": "npx playwright test --config=e2e/playwright.config.ts --ui",
    "test:e2e:chromium": "npx playwright test --config=e2e/playwright.config.ts --project=chromium",
    "test:e2e:prod": "cross-env BASE_URL=https://crosswithfriends.com npx playwright test --config=e2e/playwright.config.ts",
    "test:e2e:chromium:prod": "cross-env BASE_URL=https://crosswithfriends.com npx playwright test --config=e2e/playwright.config.ts --project=chromium",
    "test:e2e:report": "npx playwright show-report e2e/playwright-report",
    "stylelint": "stylelint \"src/**/*.css\"",
    "stylelint:fix": "stylelint \"src/**/*.css\" --fix",
    "loadtest:seed": "psql -d ${PGDATABASE:-dfac} -f loadtest/seed.sql",
    "loadtest": "pnpm loadtest:seed && k6 run loadtest/api-read.js",
    "loadtest:auth": "pnpm loadtest:seed && k6 run loadtest/api-auth.js",
    "loadtest:ws": "pnpm loadtest:seed && k6 run loadtest/websocket.js",
    "loadtest:write": "pnpm loadtest:seed && k6 run loadtest/api-write.js",
    "loadtest:all": "pnpm loadtest:seed && k6 run loadtest/api-read.js && k6 run loadtest/api-auth.js && k6 run loadtest/api-write.js && k6 run loadtest/websocket.js",
    "loadtest:smoke": "K6_PROFILE=smoke pnpm loadtest:all",
    "loadtest:full": "K6_PROFILE=load pnpm loadtest:all",
    "loadtest:stress": "K6_PROFILE=stress pnpm loadtest:all"
  },
  "lint-staged": {
    "!(backfills|utils|e2e|loadtest)/**/*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0",
      "prettier --write"
    ],
    "(backfills|utils)/**/*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ],
    "src/**/*.css": [
      "stylelint --max-warnings=0",
      "prettier --write"
    ]
  }
}
